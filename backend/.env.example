# Environment Configuration
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://friedays_user:your_password@localhost:5432/friedays_db

# JWT/Sessions
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
SESSION_SECRET=your-super-secret-session-key-change-in-production-min-32-chars
JWT_EXPIRY=7d

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-not-regular-password
SMTP_FROM=noreply@friedays.com

# OAuth - Google
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# OAuth - Facebook
FACEBOOK_APP_ID=your-app-id
FACEBOOK_APP_SECRET=your-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:5000/auth/facebook/callback

# Security
BCRYPT_ROUNDS=12
PASSWORD_RESET_EXPIRY_MINUTES=30
EMAIL_VERIFICATION_EXPIRY_HOURS=24
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MINUTES=15
ACCOUNT_LOCKOUT_MINUTES=30

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8000,https://app.friedays.com

# App
APP_NAME=Friedays
APP_URL=http://localhost:3000
